# Copy these values into .env.local for local development.
# For Vercel, add the same keys in Project Settings > Environment Variables.

SECRET_KEY=change-this-to-a-long-random-secret
APP_BASE_URL=http://127.0.0.1:5000

# Gmail example:
# Use a Gmail app password, not your normal Gmail password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Optional: send every login alert to one mailbox instead of the user account email.
# LOGIN_ALERT_EMAIL=security@example.com
